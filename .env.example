# Signaly 環境変数
# このファイルは変数名のみ記載（値なし）。git 管理対象。
# ローカル開発は .env.local.example を参照してください（1Password 不要）。
#
# 本番 VPS（signaly.gucchii.com / ルート公開）は .env.tpl 経由で
# 1Password から注入される（setup.sh / deploy.yml が書き込む）。

TARGET_DIR=

DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
APP_URL=
TUNNEL_NAME=
TUNNEL_HOSTNAME=
ALLOWED_EMAILS=
SECRET_KEY=
LOGIN_WEBHOOK_URL=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
