# Signaly 環境変数
# このファイルは変数名のみ記載（値なし）。git 管理対象。
#
# ── ローカル開発（WSL MySQL）──────────────────────────────────────────────────
# .env.local を手動作成（git 管理外）して以下を記載する:
#
#   DB_NAME=app_signaly
#   DB_USER=root
#   DB_PASSWORD=
#   DB_HOST=127.0.0.1
#   DB_PORT=3306
#
# ── 本番 VPS ──────────────────────────────────────────────────────────────────
# .env.tpl 経由で 1Password から注入される（setup.sh / deploy.yml が書き込む）

DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
