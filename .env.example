# Signaly 環境変数
# このファイルは変数名のみ記載（値なし）。git 管理対象。
#
# ── ローカル開発（WSL MySQL）──────────────────────────────────────────────────
# .env.local を手動作成（git 管理外）して以下を記載する:
#
#   DB_NAME=app_signaly
#   DB_USER=root
#   DB_PASSWORD=
#   DB_HOST=127.0.0.1
#   DB_PORT=3306
#
#   GOOGLE_CLIENT_ID=...（Google Cloud Console で取得）
#   GOOGLE_CLIENT_SECRET=...
#   GOOGLE_REDIRECT_URI=https://dev.example.com/auth/callback
#   APP_URL=https://dev.example.com/
#   TUNNEL_NAME=signaly-dev          # scripts/setup-tunnel.sh で設定
#   TUNNEL_HOSTNAME=dev.example.com  # 固定トンネル URL（未設定時は Quick Tunnel）
#
#   VAPID_PUBLIC_KEY=...
#   VAPID_PRIVATE_KEY='-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n'
#   VAPID_SUBJECT=mailto:you@example.com
#   ALLOWED_EMAILS=you@gmail.com,other@gmail.com
#   SECRET_KEY=...（python -c "import secrets; print(secrets.token_hex(32))" で生成）
#
#   API 認証:
#   - ブラウザ: Google OAuth + セッション Cookie（/auth/login）
#   - スクリプト: API キー（Authorization: Bearer sk_...）— Webhook URL 画面で作成
#   Webhook（/webhook/*）は認証不要
#
#   Web Push（スマホ常時通知）:
#   python scripts/gen_vapid_keys.py mailto:you@gmail.com
#   → 出力された VAPID_* を .env.local に追加
#
# ── 本番 VPS ──────────────────────────────────────────────────────────────────
# .env.tpl 経由で 1Password から注入される（setup.sh / deploy.yml が書き込む）

TARGET_DIR=

DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
APP_URL=
TUNNEL_NAME=
TUNNEL_HOSTNAME=
ALLOWED_EMAILS=
SECRET_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
