# cp .env.local.example .env.local
#
# ローカル開発用（1Password は不要）。
# Google OAuth は開発用と本番用で Google Cloud のプロジェクト/クライアントを分けること。
# 開発用クライアントは他の個人プロジェクトと共通のものを使い回してよい（本番は 1Password で分離管理）。
# 開発用クライアントの承認済みリダイレクト URI: https://<TUNNEL_HOSTNAME>/auth/callback

DB_NAME=app_signaly
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://dev.example.com/auth/callback
APP_URL=https://dev.example.com/
TUNNEL_NAME=dev-tunnel           # scripts/setup-tunnel.sh で設定（複数プロジェクト共有の場合は共通名にする）
TUNNEL_HOSTNAME=dev.example.com  # 固定トンネル URL（未設定時は Quick Tunnel）

ALLOWED_EMAILS=you@gmail.com,other@gmail.com
SECRET_KEY=  # python -c "import secrets; print(secrets.token_hex(32))" で生成

# ログイン通知（任意。未設定なら通知しない）
LOGIN_WEBHOOK_URL=

# Web Push（スマホ常時通知。任意）
# python scripts/gen_vapid_keys.py mailto:you@gmail.com の出力を追加
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@gmail.com
