[Unit]
Description=Signaly notification hub
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory={{TARGET_DIR}}/backend
EnvironmentFile={{TARGET_DIR}}/.env
ExecStart={{TARGET_DIR}}/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8002
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
