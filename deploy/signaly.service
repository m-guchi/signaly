[Unit]
Description=Signaly notification hub
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/apps/signaly/backend
EnvironmentFile=/apps/signaly/.env
ExecStart=/apps/signaly/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
